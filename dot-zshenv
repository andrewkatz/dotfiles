# Homebrew (must be early so brew-installed tools are found)
if [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Claude Code's shell snapshots don't capture chpwd/precmd hooks, so the
# `mise activate zsh` in .zshrc can't re-resolve tool versions when Claude
# cds into a project. Use shim-based activation only inside Claude Code.
if [ -n "$CLAUDECODE" ] && command -v mise &> /dev/null; then
  eval "$(mise activate zsh --shims)"
fi

export XDG_CONFIG_HOME="$HOME/.config"
export EDITOR="nvim"
export OP_BIOMETRIC_UNLOCK_ENABLED=true
export AWS_PAGER=""

# Claude Code: disable adaptive thinking (use full extended thinking instead)
export CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING=1

# Android SDK
export ANDROID_HOME=~/Library/Android/sdk

# Obj-C fork safety (Ruby/Rails on macOS)
export OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES

# Java 21 (Eclipse Temurin)
if [ -d "$HOME/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home" ]; then
  export JAVA_HOME="$HOME/Library/Java/JavaVirtualMachines/temurin-21.jdk/Contents/Home"
elif [ -x /usr/libexec/java_home ]; then
  _java_home_21="$(/usr/libexec/java_home -v 21 2>/dev/null)"
  [ -n "$_java_home_21" ] && export JAVA_HOME="$_java_home_21"
  unset _java_home_21
fi

# Drop stale Homebrew OpenJDK path if inherited from existing shells.
path=(${path:#/opt/homebrew/opt/openjdk/bin})

# Compiler flags for native gems against Java
[ -n "$JAVA_HOME" ] && export CPPFLAGS="-I${JAVA_HOME}/include"

# Claude Code's shell snapshots don't capture chpwd_functions, so zoxide's
# doctor falsely warns on every cd. Silence it only inside Claude Code.
[ -n "$CLAUDECODE" ] && export _ZO_DOCTOR=0

# PATH: language toolchains and SDKs
[ -n "$JAVA_HOME" ] && export PATH="$JAVA_HOME/bin:$PATH"
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
export PATH="/usr/local/opt/python/libexec/bin:$PATH"
export PATH="/usr/local/opt/terraform@0.12/bin:$PATH"
export PATH="/usr/local/gradle/bin:$PATH"
export PATH="/usr/local/share/npm/bin:$PATH"
export PATH="/usr/local/sbin:$PATH"
export PATH="/usr/local/heroku/bin:$PATH"
export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# PATH: Android SDK (append; less critical)
export PATH="${PATH}:${ANDROID_HOME}/tools"
export PATH="${PATH}:${ANDROID_HOME}/tools/bin"
export PATH="${PATH}:${ANDROID_HOME}/platform-tools"
export PATH="${PATH}:${HOME}/.composer/vendor/bin"
export PATH="${PATH}:${HOME}/.pub-cache/bin"

# PATH: repo + user dirs (highest priority, prepended last)
export PATH="./bin:$HOME/.bin:$HOME/.local/bin:$HOME/bin:$HOME/.config/scripts/:$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
typeset -U PATH
