# vim: set ft=dosini:

text-color=#f2f4f8
border-color=#b897f8
background-color=#161616
width=420
height=110
padding=10
border-size=2
font=JetBrainsMono Nerd Font 10
anchor=top-right
default-timeout=7000
max-icon-size=32

[mode=do-not-disturb]
invisible=true

[mode=do-not-disturb app-name=notify-send]
invisible=false
