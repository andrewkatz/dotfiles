# Copy to ~/.config/sentry-to-developerly.env and fill in local secrets.
# Do not commit the filled-in file.

# Sentry API token with permission to read events and update/assign issues.
# Recommended scopes: event:read, event:write, project:read, org:read.
SENTRY_AUTH_TOKEN=""

# Sentry organization and project slug(s) to poll.
SENTRY_ORG_SLUG=""
SENTRY_PROJECT_SLUG=""
# For multiple projects, use a comma-separated list instead:
# SENTRY_PROJECT_SLUGS="project-one,project-two"

# Sentry issue assignment used to mark processed issues.
# Use "me" if your token supports it, or set an explicit "user:<id>" / "team:<id>".
SENTRY_ASSIGNEE="me"

# Query and paging defaults. The script still filters locally for unresolved + unassigned.
SENTRY_QUERY="is:unresolved"
SENTRY_ISSUE_LIMIT="100"
SENTRY_MAX_PAGES="5"
SENTRY_MAX_ISSUES_PER_RUN="25"
SENTRY_DESCRIPTION_MAX_CHARS="30000"

# Regression handling: when a previously-resolved issue starts erroring again,
# create a fresh "[Sentry] [REGRESSION]" task (the developerly CLI cannot reopen
# the old one). Detected via Sentry substatus "regressed" and deduped per
# regression episode using the set_regression activity timestamp, so a re-run
# never re-fires the same regression. Set to "false" to disable.
SENTRY_HANDLE_REGRESSIONS="true"
SENTRY_REGRESSED_QUERY="is:regressed"
SENTRY_MAX_REGRESSIONS_PER_RUN="25"

# Local Developerly project name from ~/.config/developerly/config.toml.
DEVELOPERLY_PROJECT="VIA"
DEVELOPERLY_CLI="$HOME/.local/bin/developerly"

# Optional overrides.
# SENTRY_BASE_URL="https://sentry.io"
# SENTRY_TO_DEVELOPERLY_LOCK_FILE="/tmp/sentry-to-developerly.lock"
# SENTRY_TO_DEVELOPERLY_STATE_FILE="$HOME/.cache/sentry-to-developerly/processed.json"
