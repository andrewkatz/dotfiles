# Copy to ~/.config/calendar-blocker.env and fill in local config/secrets.
# Do not commit the filled-in file or OAuth tokens.

# Source: personal "Caitlin and Andrew" shared calendar.
# Target: work/Giant Partners calendar to block.
# Use `~/.config/scripts/calendar-blocker/sync --list-calendars source` and
# `~/.config/scripts/calendar-blocker/sync --list-calendars target` after auth
# to find these IDs.
CALENDAR_BLOCKER_SOURCE_CALENDAR_ID=""
CALENDAR_BLOCKER_TARGET_CALENDAR_ID=""

# Any source event whose title/summary starts with this exact prefix OR contains
# one of the comma-separated marker strings becomes a generic unavailable block
# on the target calendar. The default marker is the white-small-square emoji.
CALENDAR_BLOCKER_TITLE_PREFIX="Andrew -"
CALENDAR_BLOCKER_TITLE_CONTAINS_MARKERS="▫️"
CALENDAR_BLOCKER_TARGET_SUMMARY="Unavailable"
CALENDAR_BLOCKER_TARGET_DESCRIPTION="Managed by calendar-blocker. Source event details intentionally omitted."
CALENDAR_BLOCKER_TARGET_VISIBILITY="private"

# Timed events are expanded by this many minutes on the work calendar.
# All-day source events stay all-day.
CALENDAR_BLOCKER_BUFFER_BEFORE_MINUTES="30"
CALENDAR_BLOCKER_BUFFER_AFTER_MINUTES="30"
# Optional Google Calendar color ID, e.g. "8".
# CALENDAR_BLOCKER_TARGET_COLOR_ID=""

# Sync a rolling window around now. Stale managed blockers inside this window
# are deleted when the source event is deleted, moved, renamed, or unflagged.
CALENDAR_BLOCKER_WINDOW_PAST_DAYS="2"
CALENDAR_BLOCKER_WINDOW_FUTURE_DAYS="180"

# Google OAuth Desktop client JSON downloaded from Google Cloud Console.
CALENDAR_BLOCKER_CLIENT_SECRET_FILE="$HOME/.config/calendar-blocker/client_secret.json"

# OAuth tokens generated by `sync --authorize source` and `sync --authorize target`.
# If one Google account can read the source calendar and write the target calendar,
# you may set both paths to the same token file and authorize once.
CALENDAR_BLOCKER_SOURCE_TOKEN_FILE="$HOME/.config/calendar-blocker/source-token.json"
CALENDAR_BLOCKER_TARGET_TOKEN_FILE="$HOME/.config/calendar-blocker/target-token.json"

# Optional overrides.
CALENDAR_BLOCKER_LOCK_FILE="/tmp/calendar-blocker.lock"
CALENDAR_BLOCKER_SEND_UPDATES="none"
