# vim: ft=zsh

# Setup zinit plugin manager
ZINIT_HOME="${XDG_DATA_HOME:-${HOME}/.local/share}/zinit/zinit.git"
[ ! -d $ZINIT_HOME ] && mkdir -p "$(dirname $ZINIT_HOME)"
[ ! -d $ZINIT_HOME/.git ] && git clone https://github.com/zdharma-continuum/zinit.git "$ZINIT_HOME"
source "${ZINIT_HOME}/zinit.zsh"

# Install plugins
# fzf-tab must be loaded before plugins that wrap widgets (e.g. syntax-highlighting)
# and after compinit, but we use turbo mode below to defer the heavy ones.
zinit light zsh-users/zsh-completions
zinit light Aloxaf/fzf-tab

# Turbo-load these after the prompt is shown for a snappier startup
zinit ice wait lucid atload'_zsh_autosuggest_start'
zinit light zsh-users/zsh-autosuggestions
zinit ice wait lucid
zinit light zsh-users/zsh-syntax-highlighting

# Key bindings for autosuggestions
bindkey '^n' autosuggest-accept

source ~/.zsh/history.zsh
source ~/.zsh/completion.zsh
source ~/.zsh/aliases.zsh
[ -f ~/.zsh_secrets ] && source ~/.zsh_secrets

# Initialize completions: only regenerate the dump once per day, otherwise
# skip the security audit for a much faster startup.
autoload -Uz compinit
_zcompdump_stale=(~/.zcompdump(N.mh+24))
if (( ${#_zcompdump_stale} )); then
  compinit
else
  compinit -C
fi
unset _zcompdump_stale
zinit cdreplay -q

# Source function files AFTER compinit so compdef calls inside them work.
for f in ~/.zsh/functions/*.zsh(N); do source "$f"; done

# fzf + carbonfox theme
export FZF_DEFAULT_OPTS=" \
--color=bg+:#2a2a2a,bg:#161616,spinner:#dfdfe0,hl:#dc5e95 \
--color=fg:#f2f4f8,header:#dc5e95,info:#b897f8,pointer:#dfdfe0 \
--color=marker:#b897f8,fg+:#f2f4f8,prompt:#b897f8,hl+:#dc5e95 \
--color=selected-bg:#353535 \
--multi"
source <(fzf --zsh)
bindkey -r '^R'

if command -v mise &> /dev/null; then
  eval "$(mise activate zsh)"
fi

if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

eval "$(zoxide init --cmd cd zsh)"

# Starship prompt
eval "$(starship init zsh)"

# OSC 7: tell the terminal emulator about the current working directory.
chpwd() {
  printf '\033]7;file://%s%s\033\\' "$HOST" "$PWD"
}

ulimit -n 2560
export AWS_PAGER=""
