{
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "ruby-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "compound-engineering-plugin": {
      "source": {
        "source": "git",
        "url": "https://github.com/EveryInc/every-marketplace.git"
      }
    }
  },
  "hooks": {
    "Elicitation": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh notification",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh permission_request",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh post_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ],
        "matcher": "*"
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh post_tool_failure",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh pre_tool_use",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh session_end",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh stop",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.claude/hooks/tmux-icon.sh ",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "[ -n \"$SUPERSET_HOME_DIR\" ] && [ -x \"$SUPERSET_HOME_DIR/hooks/notify.sh\" ] && SUPERSET_AGENT_ID=claude \"$SUPERSET_HOME_DIR/hooks/notify.sh\" || true",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "/Users/andrewkatz/.claude/hooks/developerly-status.sh user_prompt_submit",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "command": "~/.config/scripts/claude-worktree-create",
            "type": "command"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "command": "~/.config/scripts/claude-worktree-remove",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "plan",
    "disableAutoMode": "disable",
    "additionalDirectories": [
      "~/.local/share/mise",
      "~/.cache"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "model": "opus",
  "tui": "fullscreen",
  "agentPushNotifEnabled": true,
  "statusLine": {
    "command": "~/.config/scripts/claude-statusline",
    "type": "command"
  }
}
