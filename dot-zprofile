# Auto-start Hyprland only on Linux machines using the full dev profile.
if [[ "$(uname)" == "Linux" ]]; then
  dotfiles_linux_profile="${DOTFILES_LINUX_PROFILE:-}"
  dotfiles_linux_profile_file="${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles/linux-profile"

  if [[ -z "$dotfiles_linux_profile" && -r "$dotfiles_linux_profile_file" ]]; then
    dotfiles_linux_profile="$(head -n 1 "$dotfiles_linux_profile_file")"
  fi
  dotfiles_linux_profile="${dotfiles_linux_profile:l}"

  case "$dotfiles_linux_profile" in
    dev|full|hyprland|bare-arch|desktop)
      if command -v uwsm >/dev/null 2>&1 && uwsm check may-start -g 120 > /dev/null; then
        exec uwsm start hyprland-uwsm.desktop
      fi
      ;;
  esac

  unset dotfiles_linux_profile dotfiles_linux_profile_file
fi

# OrbStack (macOS only, login shell)
if [[ "$(uname)" == "Darwin" ]] ; then
  source ~/.orbstack/shell/init.zsh 2>/dev/null || :

  # macOS runs /usr/libexec/path_helper from /etc/zprofile after ~/.zshenv,
  # which can move /opt/homebrew/bin and /usr/bin back ahead of user shims and Java.
  # Re-promote Java and stowed user bins in login shells so ~/.local/bin/pi wins over global pi.
  [ -n "$JAVA_HOME" ] && export PATH="$JAVA_HOME/bin:$PATH"
  export PATH="./bin:$HOME/.bin:$HOME/.local/bin:$HOME/bin:$HOME/.config/scripts/:$HOME/.yarn/bin:$HOME/.config/yarn/global/node_modules/.bin:$PATH"
  typeset -U PATH
fi
