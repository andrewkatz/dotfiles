#!/usr/bin/env bash

set -e

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/.." && pwd)"

source "$script_dir/lib/logging.sh"
source "$script_dir/clean-broken-symlinks"

ONLY_STOW=false
LINUX_PROFILE_INPUT="${DOTFILES_LINUX_PROFILE:-}"

linux_profile_state_file() {
  printf '%s/dotfiles/linux-profile\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

normalize_linux_profile() {
  local profile
  profile="$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]')"

  case "$profile" in
    dev|full|hyprland|bare-arch|desktop)
      printf 'dev\n'
      ;;
    minimal|gaming|cachyos|catchyos|cachy|catchy|plasma|kde)
      printf 'minimal\n'
      ;;
    wsl|windows|microsoft)
      printf 'wsl\n'
      ;;
    *)
      return 1
      ;;
  esac
}

read_saved_linux_profile() {
  local profile_file
  profile_file="$(linux_profile_state_file)"

  if [ -r "$profile_file" ]; then
    head -n 1 "$profile_file"
  fi

  return 0
}

linux_profile_description() {
  case "$LINUX_PROFILE" in
    dev)
      printf 'full bare-Arch Hyprland workstation\n'
      ;;
    minimal)
      printf 'minimal CachyOS/Plasma development dotfiles\n'
      ;;
    wsl)
      printf 'headless Arch on Windows WSL (terminal + dev only)\n'
      ;;
  esac
}

write_linux_profile() {
  if [ "$(uname)" != "Linux" ]; then
    return 0
  fi

  local profile_file
  profile_file="$(linux_profile_state_file)"

  mkdir -p "$(dirname "$profile_file")"
  printf '%s\n' "$LINUX_PROFILE" > "$profile_file"
  log "Using Linux profile '$LINUX_PROFILE' ($(linux_profile_description))."
}

show_help() {
  cat <<EOF
Usage: $(basename "$0") [--only-stow] [--profile PROFILE]

Options:
  --only-stow        Only run Pi layout and stow commands (skip package install, shell setup, etc.)
  --profile PROFILE  Linux install profile. Defaults to the saved profile, then 'dev'.

Linux profiles:
  dev      Full bare-Arch development desktop: shared dev packages plus Hyprland, Wayland desktop tools, optional desktop apps, and desktop hooks.
  minimal  CachyOS/Plasma-friendly setup: shared dev packages plus 1Password and Chromium; skips Hyprland installs/autostart, optional desktop apps, and VoxType GPU hooks.
  wsl      Headless Arch on Windows WSL: shared CLI/dev packages only; skips fonts, GUI apps, Hyprland, and desktop hooks.

Profile aliases:
  dev:     full, hyprland, bare-arch, desktop
  minimal: gaming, cachyos, catchyos, cachy, plasma, kde
  wsl:     windows, microsoft

Environment:
  DOTFILES_LINUX_PROFILE can also set the Linux profile.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --only-stow)
      ONLY_STOW=true
      ;;
    --profile)
      shift
      if [ "$#" -eq 0 ]; then
        log_error "--profile requires a value"
        exit 1
      fi
      LINUX_PROFILE_INPUT="$1"
      ;;
    --profile=*)
      LINUX_PROFILE_INPUT="${1#--profile=}"
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    *)
      log_error "Unknown argument: $1"
      exit 1
      ;;
  esac
  shift
done

LINUX_PROFILE_RAW="$LINUX_PROFILE_INPUT"
if [ -z "$LINUX_PROFILE_RAW" ] && [ "$(uname)" = "Linux" ]; then
  LINUX_PROFILE_RAW="$(read_saved_linux_profile)"
fi
if [ -z "$LINUX_PROFILE_RAW" ]; then
  LINUX_PROFILE_RAW="dev"
fi

if ! LINUX_PROFILE="$(normalize_linux_profile "$LINUX_PROFILE_RAW")"; then
  log_error "Unknown Linux profile: $LINUX_PROFILE_RAW"
  show_help
  exit 1
fi

run_stow() {
  "$script_dir/setup-pi-agent-layout"

  log "Installing dotfiles using stow..."
  source "$script_dir/lib/stow.sh"
  run_stow_command() {
    set +e
    "$@" 2>&1 | clean_stow_output
    local status=${PIPESTATUS[0]}
    set -e
    return "$status"
  }

  clean_absolute_symlinks
  (cd "$repo_dir" && run_stow_command stow --verbose=2 --dotfiles -t "$HOME" .)
  clean_broken_symlinks

  log "Installing platform-specific dotfiles..."
  if [ "$(uname)" = "Darwin" ]; then
    (cd "$repo_dir" && run_stow_command stow --verbose=2 --dotfiles -t "$HOME" -d . darwin)
  elif [ "$(uname)" = "Linux" ]; then
    (cd "$repo_dir" && run_stow_command stow --verbose=2 --dotfiles -t "$HOME" -d . linux)
  fi
  clean_broken_symlinks
}

if [ "$ONLY_STOW" = true ]; then
  if [ -z "$(command -v stow)" ]; then
    log_error "stow is not installed. Run '$(basename "$0")' without --only-stow first."
    exit 1
  fi
  write_linux_profile
  run_stow
  exit 0
fi

aur_helper() {
  if command -v yay >/dev/null 2>&1; then
    printf 'yay\n'
  elif command -v paru >/dev/null 2>&1; then
    printf 'paru\n'
  else
    return 1
  fi
}

install_package_manager() {
  if [ "$(uname)" = "Darwin" ]; then
    if [ -z "$(command -v brew)" ]; then
      log "Homebrew not found, installing..."
      /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    fi
  elif [ "$(uname)" = "Linux" ]; then
    if ! aur_helper >/dev/null 2>&1; then
      log "No AUR helper found, installing yay..."
      sudo pacman -S --noconfirm --needed git base-devel
      rm -rf /tmp/yay
      git clone https://aur.archlinux.org/yay.git /tmp/yay
      pushd /tmp/yay
      makepkg -si
      popd
      rm -rf /tmp/yay
    fi
  else
    log_error "Unsupported OS"
    exit 1
  fi
}

install_stow() {
  if [ -z "$(command -v stow)" ]; then
    log "stow not found, installing..."
    if [ "$(uname)" = "Darwin" ]; then
      brew install stow
    elif [ "$(uname)" = "Linux" ]; then
      "$(aur_helper)" -S --noconfirm stow
    else
      log_error "Unsupported OS for stow installation"
      exit 1
    fi
  fi
}

change_shell_to_zsh() {
  if [[ "$SHELL" != *"zsh" ]]; then
    if [ -z "$(command -v zsh)" ]; then
      log "zsh not found, installing..."
      if [ "$(uname)" = "Darwin" ]; then
        brew install zsh
      elif [ "$(uname)" = "Linux" ]; then
        "$(aur_helper)" -S --noconfirm zsh
      else
        log_error "Unsupported OS for zsh installation"
        exit 1
      fi
    fi

    local zsh_path
    zsh_path="$(command -v zsh)"

    # chsh only accepts paths listed in /etc/shells. command -v may resolve
    # to a path that points at the same binary but isn't listed (e.g.
    # /usr/sbin/zsh on Arch, where /usr/sbin is a symlink to /usr/bin).
    # Prefer a path that's already listed; otherwise append the one we found.
    if [ -r /etc/shells ]; then
      local listed_zsh
      listed_zsh="$(grep -E '/zsh$' /etc/shells | head -n 1)"
      if [ -n "$listed_zsh" ] && [ -x "$listed_zsh" ]; then
        zsh_path="$listed_zsh"
      elif ! grep -qxF "$zsh_path" /etc/shells; then
        log "Adding $zsh_path to /etc/shells so chsh will accept it..."
        printf '%s\n' "$zsh_path" | sudo tee -a /etc/shells >/dev/null
      fi
    fi

    log "Changing default shell to zsh ($zsh_path)..."
    chsh -s "$zsh_path"
    log "Default shell changed to zsh. Continuing install; logout/login later for the shell change to take effect."
  fi
}

init_tpm() {
  if [ ! -d "$HOME/.config/tmux/plugins/tpm" ] ; then
    log "Initializing Tmux Plugin Manager (TPM)..."
    mkdir -p "$HOME/.config/tmux/plugins"
    git clone https://github.com/tmux-plugins/tpm "$HOME/.config/tmux/plugins/tpm"
  fi
}

install_tpm_plugins() {
  local installer="$HOME/.config/tmux/plugins/tpm/bin/install_plugins"

  if [ ! -x "$installer" ]; then
    log "TPM installer not found at $installer; skipping tmux plugin install."
    return 0
  fi

  if ! command -v tmux >/dev/null 2>&1; then
    log "tmux not installed; skipping TPM plugin install."
    return 0
  fi

  log "Installing tmux plugins via TPM..."
  "$installer"
}

arch_manifest_files() {
  printf '%s\n' "$repo_dir/Archfile"

  if [ "$LINUX_PROFILE" != "wsl" ]; then
    printf '%s\n' "$repo_dir/Archfile.desktop"
  fi

  if [ "$LINUX_PROFILE" = "dev" ]; then
    printf '%s\n' "$repo_dir/Archfile.hyprland"
  fi
}

archfile_packages() {
  # Print all package names from the given manifests, ignoring blank lines,
  # full-line comments, and inline comments.
  local manifest

  for manifest in "$@"; do
    [ -f "$manifest" ] || continue
    sed 's/[[:space:]]*#.*$//' "$manifest"
  done | awk 'NF { print $1 }' | awk '!seen[$0]++' | tr '\n' ' '
}

install_brewfile_taps() {
  local brewfile="$repo_dir/Brewfile"
  local taps=()
  local tap

  [ -f "$brewfile" ] || return 0

  while IFS= read -r tap; do
    [ -n "$tap" ] && taps+=("$tap")
  done < <(grep -E '^[[:space:]]*tap[[:space:]]+"' "$brewfile" | cut -d '"' -f 2)

  if [ "${#taps[@]}" -gt 0 ]; then
    log "Tapping Brewfile taps..."
    brew tap "${taps[@]}"
  fi
}

install_packages() {
  if [ "$(uname)" = "Darwin" ]; then
    if [ -f "$repo_dir/Brewfile" ]; then
      install_brewfile_taps
      log "Installing Brewfile packages..."
      brew bundle --file="$repo_dir/Brewfile"
    fi
  elif [ "$(uname)" = "Linux" ]; then
    local manifests=()
    local manifest
    local manifest_names=""
    local packages

    while IFS= read -r manifest; do
      if [ -f "$manifest" ]; then
        manifests+=("$manifest")
        manifest_names="${manifest_names:+$manifest_names, }$(basename "$manifest")"
      fi
    done < <(arch_manifest_files)

    if [ "${#manifests[@]}" -gt 0 ]; then
      log "Installing Arch packages for '$LINUX_PROFILE' profile from $manifest_names..."
      packages="$(archfile_packages "${manifests[@]}")"
      if [ -n "$packages" ]; then
        # shellcheck disable=SC2086
        "$(aur_helper)" -S --needed --noconfirm $packages
      fi
    fi
  fi
}

install_pi_dev() {
  # Install pi into an isolated npm prefix so it lives at
  # $HOME/.local/share/pi-cli/bin/pi and never sits inside a mise-managed
  # Node's bin dir. That way `mise activate zsh` can't prepend pi ahead of the
  # ~/.local/bin/pi shim (which handles PI_DEFAULT_* env overrides and pins
  # the runtime to the global mise Node).
  local pi_prefix="$HOME/.local/share/pi-cli"
  local pi_package="@earendil-works/pi-coding-agent"
  local node_dir

  if ! command -v mise >/dev/null 2>&1; then
    log_error "mise not found; cannot install pi"
    return 1
  fi

  node_dir="$(mise where -C "$HOME" node 2>/dev/null || true)"
  if [ -z "$node_dir" ]; then
    log "No global mise node; installing node@lts..."
    mise use -g node@lts
    node_dir="$(mise where -C "$HOME" node)"
  fi

  # Cleanup: prior installs may have placed pi inside the mise node (via
  # pi.dev/install.sh or `npm install -g`), which `mise activate` prepends
  # ahead of ~/.local/bin and shadows the shim.
  if [ -e "$node_dir/bin/pi" ]; then
    log "Removing pi from mise-managed node to avoid PATH shadowing..."
    PATH="$node_dir/bin:$PATH" npm uninstall -g "$pi_package" >/dev/null 2>&1 || true
  fi

  # Cleanup: if pi was tracked via `mise use -g npm:...`, drop it too.
  if mise ls 2>/dev/null | grep -q "npm:$pi_package"; then
    log "Removing mise-tracked npm:$pi_package..."
    mise use -g --rm "npm:$pi_package" >/dev/null 2>&1 || true
  fi

  log "Installing pi into $pi_prefix (isolated from mise PATH)..."
  PATH="$node_dir/bin:$PATH" npm install -g --prefix="$pi_prefix" --silent "$pi_package"
}

configure_claude_mcp() {
  local firecrawl_command="$HOME/.local/bin/claude-firecrawl-mcp"
  local get_output

  if [ -z "$(command -v claude)" ]; then
    log "claude not found; skipping Claude MCP setup."
    return 0
  fi

  if [ ! -x "$firecrawl_command" ]; then
    log_error "Missing $firecrawl_command; skipping Claude Firecrawl MCP setup."
    return 0
  fi

  if get_output="$(claude mcp get firecrawl 2>/dev/null)"; then
    if printf '%s\n' "$get_output" | grep -Fq "Command: $firecrawl_command"; then
      log "Claude Firecrawl MCP server already configured."
      return 0
    fi

    log "Updating Claude Firecrawl MCP server to use $firecrawl_command..."
    claude mcp remove firecrawl -s user >/dev/null || true
  else
    log "Registering Claude Firecrawl MCP server..."
  fi

  if ! claude mcp add --scope user firecrawl -- "$firecrawl_command" >/dev/null; then
    log_error "Failed to register Claude Firecrawl MCP server."
  fi
}

install_developerly() {
  if [ -z "$(command -v developerly)" ]; then
    log "developerly not found, installing..."
    curl -fsSL https://raw.githubusercontent.com/getcomfortly/developerly-cli/main/install.sh | sh
  fi

  # Make developerly visible to this script even if ~/.local/bin isn't on PATH yet.
  if [ -z "$(command -v developerly)" ] && [ -x "$HOME/.local/bin/developerly" ]; then
    export PATH="$HOME/.local/bin:$PATH"
  fi

  if command -v developerly >/dev/null 2>&1; then
    log "Installing developerly hooks..."
    developerly hooks install
    log "Installing developerly skills..."
    developerly skill install --global --force
  else
    log_error "developerly install appears to have failed; skipping hooks/skills."
  fi
}

install_pacman_hooks() {
  local hook

  if [ "$LINUX_PROFILE" != "dev" ]; then
    log "Removing dotfiles desktop pacman hooks for '$LINUX_PROFILE' profile..."
    if [ -d /etc/pacman.d/hooks ]; then
      for hook in "$repo_dir"/hooks/*.hook; do
        [ -e "$hook" ] || continue
        sudo rm -f "/etc/pacman.d/hooks/$(basename "$hook")"
      done
    fi
    return 0
  fi

  log "Installing pacman hooks..."
  sudo mkdir -p /etc/pacman.d/hooks
  sudo cp "$repo_dir"/hooks/*.hook /etc/pacman.d/hooks/
}

setup_voxtype_gpu() {
  if [ "$LINUX_PROFILE" != "dev" ]; then
    log "Skipping VoxType GPU setup for '$LINUX_PROFILE' profile."
    return 0
  fi

  if command -v voxtype >/dev/null 2>&1; then
    log "Ensuring VoxType GPU acceleration is enabled..."
    sudo voxtype setup gpu --enable
  fi
}

source "$script_dir/ss"

write_linux_profile
install_package_manager
install_stow
change_shell_to_zsh
init_tpm

run_stow

install_packages
install_tpm_plugins
install_pi_dev
configure_claude_mcp
install_developerly

# install_secrets uses sops + age (see bin/ss). On a fresh box without an
# age key, this is optional and should only print setup instructions. Re-run
# bin/ss after the key is in place.
install_secrets || log "Skipping secrets install; re-run bin/ss after seeding the age key."

if [ "$(uname)" = "Linux" ]; then
  install_pacman_hooks
  setup_voxtype_gpu
fi
