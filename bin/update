#!/usr/bin/env bash

main()
{
  update_brew
  update_arch
  update_vim

  log "done"
}

update_brew()
{
  if [ "$(uname)" = "Darwin" ]; then
    log "homebrew"
    brew update
    brew upgrade
    brew cleanup
  fi
}

update_arch()
{
  if [ "$(uname)" = "Linux" ]; then
    local helper
    helper="$(aur_helper)" || return 1

    log "$helper"
    "$helper" -Syu --noconfirm
  fi
}

aur_helper()
{
  if command -v yay >/dev/null 2>&1; then
    printf 'yay\n'
  elif command -v paru >/dev/null 2>&1; then
    printf 'paru\n'
  else
    echo "No AUR helper found (expected yay or paru)." >&2
    return 1
  fi
}

update_vim()
{
  log "vim"
  nvim +"lua require('lazy').update({wait=true})" +qa
}

log()
{
  msg="$1"
  echo -e "$(tput setaf 4)[update] $msg$(tput sgr0)"
}

main
