#!/usr/bin/env bash

set -e

source "$(dirname "$0")/lib/logging.sh"

# Locations (overridable via env for testing)
SECRETS_REPO_URL="${SECRETS_REPO_URL:-git@github.com:andrewkatz/dotfiles-secrets.git}"
SECRETS_REPO_DIR="${SECRETS_REPO_DIR:-$HOME/Work/dotfiles-secrets}"
SECRETS_FILE="${SECRETS_FILE:-$SECRETS_REPO_DIR/secrets.yaml}"
SOPS_AGE_KEY_FILE="${SOPS_AGE_KEY_FILE:-$HOME/.config/sops/age/keys.txt}"
MACHINE_NAME_FILE="${MACHINE_NAME_FILE:-$HOME/.config/dotfiles/machine_name}"
ZSH_SECRETS_FILE="${ZSH_SECRETS_FILE:-$HOME/.zsh_secrets}"

# Tooling preconditions. Each returns non-zero so install_secrets can soft-fail
# without aborting the broader install run.
check_secrets_tooling() {
  local missing=()
  command -v sops >/dev/null 2>&1 || missing+=("sops")
  command -v jq   >/dev/null 2>&1 || missing+=("jq")
  command -v git  >/dev/null 2>&1 || missing+=("git")
  if [ ${#missing[@]} -gt 0 ]; then
    log_error "Missing required tools for secrets: ${missing[*]}"
    return 1
  fi

  if [ ! -f "$SOPS_AGE_KEY_FILE" ]; then
    log "No sops age key configured at $SOPS_AGE_KEY_FILE; skipping private secrets."
    log "To enable secrets later, copy the key from a known-good machine, e.g.:"
    log "  mkdir -p $(dirname "$SOPS_AGE_KEY_FILE")"
    log "  scp known-good:$SOPS_AGE_KEY_FILE $SOPS_AGE_KEY_FILE"
    log "  chmod 600 $SOPS_AGE_KEY_FILE"
    return 1
  fi

  return 0
}

github_https_from_ssh() {
  local url="$1"
  case "$url" in
    git@github.com:*)
      printf 'https://github.com/%s\n' "${url#git@github.com:}"
      ;;
    ssh://git@github.com/*)
      printf 'https://github.com/%s\n' "${url#ssh://git@github.com/}"
      ;;
    *)
      printf '%s\n' "$url"
      ;;
  esac
}

ensure_secrets_repo() {
  if [ ! -d "$SECRETS_REPO_DIR/.git" ]; then
    log "Cloning secrets repo to $SECRETS_REPO_DIR..."
    mkdir -p "$(dirname "$SECRETS_REPO_DIR")"
    if ! git clone "$SECRETS_REPO_URL" "$SECRETS_REPO_DIR"; then
      # SSH may not be set up on a fresh box (e.g. WSL). If the configured URL
      # is an SSH GitHub URL, retry with HTTPS so git's credential helper /
      # `gh auth login` can carry the auth.
      local https_url
      https_url="$(github_https_from_ssh "$SECRETS_REPO_URL")"
      if [ "$https_url" != "$SECRETS_REPO_URL" ]; then
        log "SSH clone failed; retrying via HTTPS ($https_url)..."
        rm -rf "$SECRETS_REPO_DIR"
        if ! git clone "$https_url" "$SECRETS_REPO_DIR"; then
          log_error "Failed to clone $SECRETS_REPO_URL (SSH) or $https_url (HTTPS)."
          log_error "Authenticate first: 'gh auth login' (HTTPS) or 'ssh -T git@github.com' (SSH)."
          return 1
        fi
      else
        log_error "Failed to clone $SECRETS_REPO_URL"
        log_error "Authenticate first: 'gh auth login' (HTTPS) or 'ssh -T git@github.com' (SSH)."
        return 1
      fi
    fi
  else
    git -C "$SECRETS_REPO_DIR" pull --ff-only --quiet 2>/dev/null || \
      log_error "Could not fast-forward $SECRETS_REPO_DIR (continuing with local copy)"
  fi

  if [ ! -f "$SECRETS_FILE" ]; then
    log_error "Secrets file missing: $SECRETS_FILE"
    return 1
  fi

  return 0
}

# Migrate the legacy repo-relative machine_name file, if present, to the new
# stable location under ~/.config/dotfiles/.
migrate_legacy_machine_name() {
  local legacy
  for legacy in \
    "$(dirname "$0")/../.machine_name" \
    "$PWD/.machine_name"
  do
    if [ -f "$legacy" ] && [ ! -f "$MACHINE_NAME_FILE" ]; then
      mkdir -p "$(dirname "$MACHINE_NAME_FILE")"
      mv "$legacy" "$MACHINE_NAME_FILE"
      log "Migrated $legacy -> $MACHINE_NAME_FILE"
      return
    fi
  done
}

get_machine_name() {
  migrate_legacy_machine_name

  if [ ! -f "$MACHINE_NAME_FILE" ]; then
    # List all top-level sections in the encrypted file except "common".
    local names
    names=$(sops --decrypt --output-type json "$SECRETS_FILE" \
              | jq -r 'keys[] | select(. != "common" and . != "sops")')
    if [ -z "$names" ]; then
      log_error "No machine sections found in $SECRETS_FILE"
      return 1
    fi

    echo "Available machine names:" >&2
    local machine_name
    select machine_name in $names; do
      if [ -n "$machine_name" ]; then
        echo "Selected machine name: $machine_name" >&2
        break
      else
        echo "Invalid selection, please try again." >&2
      fi
    done
    mkdir -p "$(dirname "$MACHINE_NAME_FILE")"
    echo "$machine_name" > "$MACHINE_NAME_FILE"
  fi

  cat "$MACHINE_NAME_FILE"
}

backup_secrets() {
  if [ -f "$ZSH_SECRETS_FILE" ]; then
    mv "$ZSH_SECRETS_FILE" "${ZSH_SECRETS_FILE}.bak"
  fi
}

# Emit `export KEY=...` lines for one top-level section of the decrypted file.
# Values are JSON-encoded (double-quoted, with \" and \\ escaped). This intentionally
# preserves shell expansion of $VAR and $(cmd) inside values, matching the legacy
# 1Password-based bin/ss behavior so existing values like "$HOME/dev" still work.
# Nested objects/arrays are reserved for richer secret types like `files:` and are
# intentionally skipped here.
emit_section() {
  local section="$1"
  sops --decrypt --output-type json "$SECRETS_FILE" \
    | jq -r --arg section "$section" '
        (.[$section] // {})
        | to_entries[]
        | select(.value | type | IN("string", "number", "boolean"))
        | "export \(.key)=\(.value | tostring | @json)"
      '
}

# Emit JSONL entries from a section's optional `files:` array. Each entry is:
#   { path: ".ssh/id_ed25519", mode: "600", content: "..." }
emit_secret_file_entries() {
  local section="$1"
  sops --decrypt --output-type json "$SECRETS_FILE" \
    | jq -c --arg section "$section" '
        (.[$section].files // [])
        | if type == "array" then .[] else empty end
        | {
            path: (.path // ""),
            mode: (.mode // "600" | tostring),
            content: (.content // "" | tostring)
          }
      '
}

resolve_secret_file_path() {
  local secret_path="$1"
  local target

  case "$secret_path" in
    ""|*$'\n'*|".."|../*|*/..|*/../*)
      log_error "Refusing unsafe secret file path: $secret_path"
      return 1
      ;;
    \~/*)
      target="$HOME/${secret_path#\~/}"
      ;;
    \$HOME/*)
      target="$HOME/${secret_path#\$HOME/}"
      ;;
    /*)
      target="$secret_path"
      ;;
    *)
      target="$HOME/$secret_path"
      ;;
  esac

  case "$target" in
    "$HOME"/*)
      printf '%s\n' "$target"
      ;;
    *)
      log_error "Refusing to write secret file outside HOME: $secret_path"
      return 1
      ;;
  esac
}

install_secret_files_for_section() {
  local section="$1"
  local entry secret_path mode target parent tmp

  while IFS= read -r entry; do
    [ -n "$entry" ] || continue

    secret_path="$(printf '%s' "$entry" | jq -r '.path')"
    mode="$(printf '%s' "$entry" | jq -r '.mode')"

    case "$mode" in
      [0-7][0-7][0-7]|[0-7][0-7][0-7][0-7])
        ;;
      *)
        log_error "Invalid mode '$mode' for secret file '$secret_path'; using 600."
        mode="600"
        ;;
    esac

    target="$(resolve_secret_file_path "$secret_path")" || continue
    parent="$(dirname "$target")"

    mkdir -p "$parent"

    # Keep the standard secret directories private even if they already existed
    # with broader permissions.
    case "$parent" in
      "$HOME/.ssh"|"$HOME/.ssh"/*)
        chmod 700 "$HOME/.ssh" "$parent" 2>/dev/null || true
        ;;
      "$HOME/.aws"|"$HOME/.aws"/*)
        chmod 700 "$HOME/.aws" "$parent" 2>/dev/null || true
        ;;
    esac

    tmp="$(mktemp "$parent/.secret.XXXXXX")"
    printf '%s' "$entry" | jq -r '.content' > "$tmp"
    chmod "$mode" "$tmp"
    mv "$tmp" "$target"
    log "Wrote $target"
  done < <(emit_secret_file_entries "$section")
}

install_secret_files() {
  local section="$1"

  install_secret_files_for_section "common"
  install_secret_files_for_section "$section"
}

install_secrets() {
  log "Installing secrets from sops..."

  if ! check_secrets_tooling; then
    return 1
  fi

  if ! ensure_secrets_repo; then
    log_error "Skipping secrets install."
    return 1
  fi

  local section
  section=$(get_machine_name) || return 1

  backup_secrets

  {
    echo "# Generated by bin/ss on $(date -Iseconds)"
    echo "# Source: $SECRETS_FILE"
    echo "# Machine section: $section"
    emit_section "common"
    emit_section "$section"
  } > "$ZSH_SECRETS_FILE"

  chmod 600 "$ZSH_SECRETS_FILE"
  log "Wrote $ZSH_SECRETS_FILE"

  install_secret_files "$section"
}

# Only run when executed directly, not when sourced
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  install_secrets
fi
